---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';

const pageTitle = "Descargar Flujo TV APK Oficial | Versión 2026 Segura";
const pageDescription = "Centro de descargas oficial de FlujoTV+. Obtén la última versión del APK para Android, TV Box, Fire Stick y Google TV. Descarga rápida y sin virus garantizada.";
---

<Layout 
  title={pageTitle}
  description={pageDescription}
>
  <Navbar />

  <main class="pt-24 pb-16 min-h-screen">
    
    <!-- Hero / Intro for Download Page -->
    <section class="py-12 relative overflow-hidden bg-carbon-950">
      <div class="absolute inset-0 bg-[url('/images/bg-forums-dark.png')] opacity-20 bg-cover bg-center mix-blend-overlay"></div>
      
      <div class="section-container relative z-10 text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-cream-100 leading-tight mb-6">
          Centro de <span class="text-gradient-ember">Descargas Oficial</span>
        </h1>
        <p class="text-xl text-cream-400 leading-relaxed mb-8">
          Descarga la última versión de Flujo TV (APK Seguro) para todos tus dispositivos Android y Smart TVs.
        </p>

        <!-- Trust Signals Row -->
        <div class="flex flex-wrap justify-center gap-4 text-sm text-cream-400 font-medium">
          <div class="flex items-center gap-2 bg-carbon-900/50 px-4 py-2 rounded-full border border-cream-500/10">
            <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Libre de Virus
          </div>
          <div class="flex items-center gap-2 bg-carbon-900/50 px-4 py-2 rounded-full border border-cream-500/10">
            <svg class="w-5 h-5 text-ember-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Velocidad Máxima
          </div>
          <div class="flex items-center gap-2 bg-carbon-900/50 px-4 py-2 rounded-full border border-cream-500/10">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
            Actualizado Mar 2026
          </div>
        </div>
      </div>
    </section>

    <!-- Main Download Options -->
    <section class="py-16 bg-carbon-950">
      <div class="section-container">
        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          
          <!-- Fire Stick / Google TV — Downloader Code -->
          <div class="download-card">
            <div class="download-card-badge bg-amber-500/10 text-amber-400 border-amber-500/20">CÓDIGO</div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-orange-500/10">
                <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" /></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-cream-50 text-lg">Fire Stick · Google TV</h3>
                <p class="text-cream-500 text-xs">Xiaomi Mi Stick incluido</p>
              </div>
            </div>
            <p class="text-cream-400 text-sm mb-4">Usa este código en la app <strong class="text-cream-200">Downloader</strong> (disponible en la tienda de apps de tu dispositivo):</p>
            <div class="text-center py-4 rounded-xl bg-carbon-800/50 border border-ember-500/15 mb-4">
              <span class="text-3xl font-mono font-bold text-ember-400 tracking-[0.3em]">{site.download.firestickCode}</span>
            </div>
            <div class="space-y-3 text-sm text-cream-400">
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>Abre Downloader, ingresa el código y la app se instala sola</span>
              </div>
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>Compatible con Fire Stick Lite, 4K, 4K Max</span>
              </div>
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>Funciona en Chromecast con Google TV</span>
              </div>
            </div>
            <a href="/instalar/fire-stick" class="mt-5 block text-center text-sm text-ember-400 hover:text-ember-300 font-semibold transition-colors">
              Ver guía paso a paso
              <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>

          <!-- Android / Tablet — Direct APK -->
          <div class="download-card">
            <div class="download-card-badge bg-sky-500/10 text-sky-400 border-sky-500/20">APK</div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-sky-500/10">
                <svg class="w-6 h-6 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-cream-50 text-lg">Android / Tablet</h3>
                <p class="text-cream-500 text-xs">Descarga directa del APK</p>
              </div>
            </div>
            <p class="text-cream-400 text-sm mb-4">Descarga e instala el archivo APK directamente en tu celular o tablet Android:</p>
            <a href={site.download.mobileApkHref} class="flex items-center justify-center gap-2 w-full py-4 rounded-xl font-bold text-white transition-all hover:brightness-110" style="background: linear-gradient(135deg, #0284c7, #06b6d4);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
              Descargar APK
            </a>
            <p class="text-center text-xs text-cream-600 mt-2">v4.2.1 · 28 MB · Android 5.0+</p>
            <div class="space-y-3 text-sm text-cream-400 mt-4">
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>Permite instalar fuentes desconocidas en Configuración</span>
              </div>
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>Funciona en cualquier teléfono o tablet Android</span>
              </div>
            </div>
            <a href="/instalar/android" class="mt-5 block text-center text-sm text-ember-400 hover:text-ember-300 font-semibold transition-colors">
              Ver instrucciones
              <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>

          <!-- TV Box Android — APK -->
          <div class="download-card">
            <div class="download-card-badge bg-purple-500/10 text-purple-400 border-purple-500/20">APK</div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-11 h-11 rounded-xl flex items-center justify-center bg-purple-500/10">
                <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.125c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125Z" /></svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-cream-50 text-lg">TV Box Android</h3>
                <p class="text-cream-500 text-xs">Todos los modelos</p>
              </div>
            </div>
            <p class="text-cream-400 text-sm mb-4">Descarga el APK usando el navegador de tu TV Box o conéctalo por USB:</p>
            <a href={site.download.mobileApkHref} class="flex items-center justify-center gap-2 w-full py-4 rounded-xl font-bold text-white transition-all hover:brightness-110" style="background: linear-gradient(135deg, #7c3aed, #8b5cf6);">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
              Descargar APK
            </a>
            <p class="text-center text-xs text-cream-600 mt-2">Conecta USB o descarga vía navegador</p>
            <div class="space-y-3 text-sm text-cream-400 mt-4">
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>También puedes usar Downloader con código {site.download.firestickCode}</span>
              </div>
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span>Compatible con Tanix, X96, HK1, T95 y más</span>
              </div>
            </div>
            <a href="/instalar/tv-box" class="mt-5 block text-center text-sm text-ember-400 hover:text-ember-300 font-semibold transition-colors">
              Ver tutorial con video
              <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>

        </div>

        <!-- Trust Bar -->
        <div class="mt-10 flex flex-wrap justify-center gap-6 text-xs text-cream-500">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
            Verificado libre de virus
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-ember-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>
            Última actualización: Marzo 2026
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" /></svg>
            Compatible con +50 dispositivos
          </div>
        </div>
      </div>
    </section>

    <!-- Compatibility Table -->
    <section class="py-12 bg-carbon-900/30">
      <div class="section-container">
        <h2 class="text-2xl font-heading font-bold text-cream-100 text-center mb-8">Dispositivos Compatibles</h2>
        <div class="overflow-x-auto max-w-4xl mx-auto">
          <table class="w-full text-sm text-left">
            <thead>
              <tr class="border-b border-cream-500/10">
                <th class="py-3 px-4 text-cream-400 font-semibold">Dispositivo</th>
                <th class="py-3 px-4 text-cream-400 font-semibold text-center">Método</th>
                <th class="py-3 px-4 text-cream-400 font-semibold text-center">Video Tutorial</th>
                <th class="py-3 px-4 text-cream-400 font-semibold text-center">Guía</th>
              </tr>
            </thead>
            <tbody class="text-cream-300">
              <tr class="border-b border-cream-500/5">
                <td class="py-3 px-4 font-medium">Amazon Fire Stick</td>
                <td class="py-3 px-4 text-center"><span class="text-amber-400 text-xs font-semibold">Código Downloader</span></td>
                <td class="py-3 px-4 text-center"><span class="text-cream-600">—</span></td>
                <td class="py-3 px-4 text-center"><a href="/instalar/fire-stick" class="text-ember-400 hover:text-ember-300 font-semibold">Ver guía</a></td>
              </tr>
              <tr class="border-b border-cream-500/5">
                <td class="py-3 px-4 font-medium">TV Box Android</td>
                <td class="py-3 px-4 text-center"><span class="text-sky-400 text-xs font-semibold">APK / Downloader</span></td>
                <td class="py-3 px-4 text-center"><span class="text-green-400 text-xs font-semibold">Disponible</span></td>
                <td class="py-3 px-4 text-center"><a href="/instalar/tv-box" class="text-ember-400 hover:text-ember-300 font-semibold">Ver guía</a></td>
              </tr>
              <tr class="border-b border-cream-500/5">
                <td class="py-3 px-4 font-medium">Google TV / Chromecast</td>
                <td class="py-3 px-4 text-center"><span class="text-amber-400 text-xs font-semibold">Código Downloader</span></td>
                <td class="py-3 px-4 text-center"><span class="text-green-400 text-xs font-semibold">Disponible</span></td>
                <td class="py-3 px-4 text-center"><a href="/instalar/google-tv" class="text-ember-400 hover:text-ember-300 font-semibold">Ver guía</a></td>
              </tr>
              <tr class="border-b border-cream-500/5">
                <td class="py-3 px-4 font-medium">Celular / Tablet Android</td>
                <td class="py-3 px-4 text-center"><span class="text-sky-400 text-xs font-semibold">APK Directo</span></td>
                <td class="py-3 px-4 text-center"><span class="text-cream-600">—</span></td>
                <td class="py-3 px-4 text-center"><a href="/instalar/android" class="text-ember-400 hover:text-ember-300 font-semibold">Ver guía</a></td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-medium">Xiaomi Mi Stick</td>
                <td class="py-3 px-4 text-center"><span class="text-amber-400 text-xs font-semibold">Código Downloader</span></td>
                <td class="py-3 px-4 text-center"><span class="text-cream-600">—</span></td>
                <td class="py-3 px-4 text-center"><a href="/instalar/xiaomi" class="text-ember-400 hover:text-ember-300 font-semibold">Ver guía</a></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Safety Info Section -->
    <section class="py-12 border-t border-cream-500/5">
      <div class="section-container">
        <div class="max-w-3xl mx-auto glass-panel p-8 rounded-3xl border border-cream-500/10 bg-carbon-900">
          <h2 class="text-2xl font-bold text-cream-100 mb-4 flex items-center gap-2">
            <svg class="w-6 h-6 text-ember-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            ¿Por qué descargar desde nuestro sitio oficial?
          </h2>
          <div class="space-y-4 text-cream-400 leading-relaxed text-sm">
            <p>
              Existen muchos sitios falsos que prometen la aplicación de Flujo TV modificada. Descargar archivos APK de fuentes no confiables puede exponer tu dispositivo a virus o robo de información.
            </p>
            <p>
              Al utilizar el <strong class="text-cream-200">código Downloader oficial ({site.download.firestickCode})</strong> o descargar el APK directamente desde nuestro sitio, te garantizamos obtener el software original.
            </p>
            <p>
              Recuerda que la aplicación es únicamente el reproductor. Para acceder al contenido (canales, películas y series), necesitas adquirir una suscripción en nuestra <a href="/planes" class="text-ember-400 hover:text-ember-300 underline">página de planes</a>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick CTA -->
    <section class="py-10">
      <div class="section-container text-center">
        <p class="text-cream-400 text-sm mb-4">¿Necesitas ayuda con la instalación?</p>
        <a href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent('Hola, necesito ayuda para instalar Flujo TV en mi dispositivo.')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 btn-outline px-8 py-3 text-sm">
          <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          Contactar Soporte por WhatsApp
        </a>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>

<style>
  .download-card {
    position: relative;
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(30, 41, 59, 0.4);
    border: 1px solid rgba(148, 163, 184, 0.08);
    transition: all 0.3s ease;
  }
  .download-card:hover {
    border-color: rgba(6, 182, 212, 0.15);
    background: rgba(30, 41, 59, 0.6);
  }
  .download-card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.6rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 0.3rem;
    border-width: 1px;
    letter-spacing: 0.05em;
  }
</style>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Flujo TV",
  "operatingSystem": "Android",
  "applicationCategory": "EntertainmentApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": "Aplicación oficial de reproducción de Flujo TV para dispositivos Android, TV Box y Fire Stick."
})} />
