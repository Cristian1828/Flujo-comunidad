---
import Layout from '../layouts/Layout.astro';
import { site } from '../config/site';

const BRAND   = 'netvantage';
const COUNTRY = 'US';
const API_URL = import.meta.env.PUBLIC_API_URL ?? 'https://api.optimait.site';

const WA_NUMBER = site.whatsappNumber;

const PLAN_MONTHS_MAP: Record<string, number> = {
  '1m': 1, '3m': 3, '6m': 7, '12m': 14,
};

const PAYPAL_LINKS: Record<string, string> = {
  '1m':  site.pricing.plans.find(p => p.id === '1m')!.paypalUrl,
  '3m':  site.pricing.plans.find(p => p.id === '3m')!.paypalUrl,
  '6m':  site.pricing.plans.find(p => p.id === '6m')!.paypalUrl,
  '12m': site.pricing.plans.find(p => p.id === '12m')!.paypalUrl,
};

const PLANS_DATA = site.pricing.plans.map(p => ({
  id:    p.id,
  name:  p.name,
  price: p.price,
  bonus: p.id === '6m'  ? '+1 Mes Gratis'
       : p.id === '12m' ? '+2 Meses Gratis'
       : null,
}));

const defaultPlan = site.pricing.plans[0];
---

<Layout
  title="Activar Plan · FlujoTV+"
  description="Activa tu membresía FlujoTV+. Streaming premium sin contratos. Activación inmediata."
  noIndex={true}
>
  <main class="co-page">

    <div class="co-wrap">

      <a href="/" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Volver al inicio
      </a>

      <!-- Header -->
      <header class="co-header">
        <div class="logo-wrap">
          <img src="/images/logo_flujo.webp" alt="FlujoTV+" class="co-logo" />
        </div>
        <div>
          <h1 class="co-brand">FlujoTV<span class="brand-cyan">+</span></h1>
          <p class="co-tagline">Streaming Premium · Activación Instantánea</p>
        </div>
      </header>

      <!-- Plan card -->
      <div class="plan-card">
        <div class="plan-left">
          <span class="plan-badge">✦ Plan Seleccionado</span>
          <p class="plan-name" id="plan-name">{defaultPlan.name}</p>
          <p class="plan-bonus" id="plan-bonus" style="display:none"></p>
        </div>
        <div class="plan-right">
          <p class="plan-price" id="plan-price">${defaultPlan.price}</p>
          <div class="plan-sub">
            <span class="plan-cur">USD</span>
            <span class="plan-per" id="plan-per" style="display:none"></span>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="form-card">
        <p class="form-heading">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Tus datos de activación
        </p>

        <form id="checkout-form" novalidate>

          <div class="field">
            <label for="f-name">Nombre Completo <span class="req">*</span></label>
            <input id="f-name" type="text" placeholder="Juan Pérez" autocomplete="name" required />
          </div>

          <div class="field">
            <label for="f-email">Correo Electrónico <span class="req">*</span></label>
            <input id="f-email" type="email" placeholder="juan@email.com" autocomplete="email" required />
            <p class="field-hint" id="email-hint"></p>
          </div>

          <div class="field">
            <label for="f-phone">Número de Teléfono <span class="req">*</span></label>
            <input id="f-phone" type="tel" autocomplete="tel" required />
          </div>

          <div class="field">
            <label for="f-user">
              Nombre de Usuario <span class="opt">(opcional)</span>
              <span class="hint-inline">solo letras, números y puntos</span>
            </label>
            <input id="f-user" type="text" placeholder="Se generará automáticamente" autocomplete="off" />
            <p class="field-hint" id="user-hint"></p>
          </div>

          <div class="error-box" id="form-error" style="display:none"></div>

          <button type="submit" class="submit-btn" id="submit-btn">
            <span id="btn-text">Continuar al pago →</span>
          </button>

        </form>
      </div>

      <p class="footer-note">Recibirás tus credenciales por WhatsApp y correo inmediatamente después del pago.</p>

    </div>
  </main>
</Layout>

<style>
  .co-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1rem 4rem;
    background: radial-gradient(ellipse 110% 60% at 20% -10%, #0c1a2e 0%, #0f172a 45%, #020617 100%);
  }

  .co-wrap { width: 100%; max-width: 480px; position: relative; z-index: 1; }

  .back-link {
    display: inline-flex; align-items: center; gap: .35rem;
    font-size: .78rem; color: rgba(255,255,255,.28); margin-bottom: 1.75rem;
    transition: color .2s; font-family: 'DM Sans', sans-serif;
  }
  .back-link:hover { color: rgba(255,255,255,.65); }

  .co-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .logo-wrap {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(6,182,212,.1); border: 1px solid rgba(6,182,212,.28);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0; padding: 6px;
  }
  .co-logo { width: 100%; height: 100%; object-fit: contain; }
  .co-brand {
    font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.6rem; font-weight: 800;
    color: #fff; line-height: 1; letter-spacing: -.02em;
  }
  .brand-cyan {
    background: linear-gradient(135deg, #22d3ee, #06b6d4);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .co-tagline { font-size: .74rem; color: rgba(255,255,255,.38); margin-top: .3rem; font-family: 'DM Sans', sans-serif; }

  .plan-card {
    background: rgba(6,182,212,.06); border: 1px solid rgba(6,182,212,.22);
    border-radius: 18px; padding: 1.4rem 1.5rem; margin-bottom: 1.25rem;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    box-shadow: 0 0 50px rgba(6,182,212,.08), inset 0 1px 0 rgba(6,182,212,.12);
    position: relative; overflow: hidden;
  }
  .plan-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(34,211,238,.45), transparent);
  }
  .plan-badge {
    font-size: .6rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    color: #06b6d4; display: block; margin-bottom: .4rem; font-family: 'DM Sans', sans-serif;
  }
  .plan-name { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.3rem; font-weight: 700; color: #fff; line-height: 1.1; }
  .plan-bonus { font-size: .72rem; color: #22d3ee; margin-top: .3rem; font-family: 'DM Sans', sans-serif; font-weight: 600; }
  .plan-right { text-align: right; flex-shrink: 0; }
  .plan-price { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2.5rem; font-weight: 800; color: #fff; line-height: 1; letter-spacing: -.03em; }
  .plan-sub { display: flex; align-items: center; justify-content: flex-end; gap: .4rem; margin-top: .2rem; }
  .plan-cur { font-size: .68rem; font-weight: 700; color: rgba(255,255,255,.35); font-family: 'DM Sans', sans-serif; }
  .plan-per { font-size: .68rem; color: rgba(255,255,255,.28); font-family: 'DM Sans', sans-serif; }

  .form-card {
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.07);
    border-radius: 18px; padding: 1.5rem; margin-bottom: 1rem;
    box-shadow: 0 8px 40px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.05);
  }
  .form-heading {
    display: flex; align-items: center; gap: .4rem; font-size: .67rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.28);
    margin-bottom: 1.35rem; font-family: 'DM Sans', sans-serif;
  }

  .field { margin-bottom: 1.1rem; }
  .field label { display: block; font-size: .8rem; font-weight: 600; color: rgba(255,255,255,.55); margin-bottom: .4rem; font-family: 'DM Sans', sans-serif; }
  .req { color: #06b6d4; margin-left: .1rem; }
  .opt { font-weight: 400; color: rgba(255,255,255,.22); font-size: .72rem; }
  .hint-inline { display: block; font-size: .67rem; font-weight: 400; color: rgba(255,255,255,.18); margin-top: .1rem; font-family: 'DM Sans', sans-serif; }

  .field input {
    width: 100%; height: 2.875rem;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.09);
    border-radius: 10px; padding: 0 1rem; color: #fff;
    font-size: .9rem; font-family: 'DM Sans', sans-serif; outline: none;
    transition: border-color .2s, box-shadow .2s, background .2s; -webkit-appearance: none;
  }
  .field input::placeholder { color: rgba(255,255,255,.16); }
  .field input:focus {
    border-color: rgba(6,182,212,.5); background: rgba(6,182,212,.04);
    box-shadow: 0 0 0 3px rgba(6,182,212,.1);
  }
  .field input.ok  { border-color: rgba(34,197,94,.4); }
  .field input.err { border-color: rgba(239,68,68,.45); }

  .field-hint { font-size: .7rem; margin-top: .35rem; min-height: 1rem; font-family: 'DM Sans', sans-serif; }
  .field-hint.ok       { color: #4ade80; }
  .field-hint.err      { color: #f87171; }
  .field-hint.checking { color: rgba(255,255,255,.3); }

  .error-box {
    background: rgba(239,68,68,.08); border: 1px solid rgba(239,68,68,.2);
    border-radius: 10px; padding: .75rem 1rem; color: #fca5a5;
    font-size: .82rem; margin-bottom: 1rem; font-family: 'DM Sans', sans-serif;
  }

  .submit-btn {
    display: block; width: 100%; padding: .95rem 1rem;
    background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%);
    border: none; border-radius: 12px; color: #fff;
    font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 24px rgba(6,182,212,.35), inset 0 1px 0 rgba(255,255,255,.15);
    transition: transform .15s, box-shadow .15s, opacity .15s; letter-spacing: .01em;
  }
  .submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(6,182,212,.5), inset 0 1px 0 rgba(255,255,255,.15);
  }
  .submit-btn:disabled { opacity: .45; cursor: not-allowed; transform: none; }

  .footer-note { text-align: center; font-size: .7rem; color: rgba(255,255,255,.18); font-family: 'DM Sans', sans-serif; }
</style>

<style is:global>
  .iti { width: 100%; display: block; }
  .iti__selected-flag { background-color: rgba(255,255,255,.05) !important; border-right: 1px solid rgba(255,255,255,.08); border-radius: 10px 0 0 10px; }
  .iti__country-list { background-color: #111827 !important; border: 1px solid rgba(6,182,212,.18) !important; border-radius: 12px !important; max-height: 220px; overflow-y: scroll !important; box-shadow: 0 12px 40px rgba(0,0,0,.6) !important; }
  .iti__country-list::-webkit-scrollbar { width: 5px; }
  .iti__country-list::-webkit-scrollbar-track { background-color: #0f172a !important; }
  .iti__country-list::-webkit-scrollbar-thumb { background: #06b6d4; border-radius: 4px; }
  .iti__country, .iti__country-list li, .iti__country-list li * { background-color: #111827 !important; }
  .iti__country:hover, .iti__country:hover *, .iti__country.iti__highlight, .iti__country.iti__highlight * { background-color: #1e293b !important; }
  .iti__country-name { color: rgba(255,255,255,.8) !important; }
  .iti__dial-code { color: #06b6d4 !important; }
  .iti--separate-dial-code .iti__selected-dial-code { color: rgba(255,255,255,.6); }
  .iti-search-wrap { position: sticky; top: 0; z-index: 2; padding: 6px 8px; background-color: #111827 !important; list-style: none; border-bottom: 1px solid rgba(6,182,212,.1); }
  .iti-custom-search { display: block; width: 100%; background-color: rgba(255,255,255,.05) !important; border: 1px solid rgba(255,255,255,.08); border-radius: 7px; color: rgba(255,255,255,.8); padding: .45rem .75rem; outline: none; font-size: .85rem; font-family: 'DM Sans', sans-serif; }
  .iti-custom-search:focus { border-color: rgba(6,182,212,.5) !important; }
  #f-phone { border-radius: 0 10px 10px 0 !important; }
</style>

<script define:vars={{ BRAND, COUNTRY, API_URL, PLANS_DATA, PLAN_MONTHS_MAP, PAYPAL_LINKS, WA_NUMBER }}>

  function goPay(url) {
    const a = document.createElement('a');
    a.href = url;
    a.referrerPolicy = 'no-referrer';
    a.rel = 'noopener noreferrer nofollow';
    document.body.appendChild(a);
    a.click();
    a.remove();
  }

  const rawPlan = new URLSearchParams(window.location.search).get('plan') || '1m';
  const plan    = PLANS_DATA.find(p => p.id === rawPlan) || PLANS_DATA[0];
  const months  = PLAN_MONTHS_MAP[plan.id] || 1;

  document.getElementById('plan-name').textContent  = plan.name;
  document.getElementById('plan-price').textContent = `$${plan.price}`;
  document.title = `Activar ${plan.name} · FlujoTV+`;

  if (plan.bonus) {
    const el = document.getElementById('plan-bonus');
    el.textContent = `✦ ${plan.bonus}`; el.style.display = '';
  }
  if (months > 1) {
    const el = document.getElementById('plan-per');
    el.textContent = `· $${(plan.price / months).toFixed(1)}/mes`; el.style.display = '';
  }

  let usernameOk = null, userTimer = null;
  const userInput = document.getElementById('f-user');
  const userHint  = document.getElementById('user-hint');

  userInput.addEventListener('input', () => {
    const raw = userInput.value;
    const clean = raw.replace(/[^a-zA-Z0-9._-]/g, '').toLowerCase();
    if (raw !== clean) userInput.value = clean;
    userHint.textContent = ''; userHint.className = 'field-hint';
    userInput.className = ''; usernameOk = null; clearTimeout(userTimer);
    if (clean.length >= 3) userTimer = setTimeout(() => checkUsername(clean), 700);
  });

  async function checkUsername(username) {
    userHint.textContent = 'Verificando disponibilidad...'; userHint.className = 'field-hint checking'; usernameOk = null;
    try {
      const r = await fetch(`${API_URL}/api/v1/checkout/check-username?username=${encodeURIComponent(username)}`);
      const d = await r.json();
      usernameOk = d.available;
      if (d.available) {
        userHint.textContent = '✓ Disponible'; userHint.className = 'field-hint ok'; userInput.className = 'ok';
      } else {
        userHint.className = 'field-hint err'; userInput.className = 'err';
        if (d.suggestion) {
          userHint.textContent = 'No disponible. Sugerencia: ';
          const link = document.createElement('a');
          link.href = '#'; link.textContent = `«${d.suggestion}»`;
          link.style.cssText = 'color:#06b6d4;text-decoration:underline';
          link.addEventListener('click', e => { e.preventDefault(); userInput.value = d.suggestion; checkUsername(d.suggestion); });
          userHint.appendChild(link);
        } else { userHint.textContent = 'No disponible. Intenta con otro.'; }
      }
    } catch { usernameOk = true; }
  }

  const emailInput = document.getElementById('f-email');
  const emailHint  = document.getElementById('email-hint');
  emailInput.addEventListener('blur', () => {
    const val = emailInput.value.trim(); if (!val) return;
    const ok = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(val);
    emailInput.className = ok ? 'ok' : 'err';
    emailHint.textContent = ok ? '' : 'Ingresa un correo electrónico válido.';
    emailHint.className = ok ? 'field-hint' : 'field-hint err';
  });
  emailInput.addEventListener('input', () => { emailInput.className = ''; emailHint.textContent = ''; emailHint.className = 'field-hint'; });

  const phoneInput = document.getElementById('f-phone');
  let iti = null;
  const loadScript = src => new Promise(resolve => { const s = document.createElement('script'); s.src = src; s.onload = resolve; document.head.appendChild(s); });

  (async () => {
    const link = document.createElement('link');
    link.rel = 'stylesheet'; link.href = 'https://cdn.jsdelivr.net/npm/intl-tel-input@18/build/css/intlTelInput.min.css';
    document.head.appendChild(link);
    await loadScript('https://cdn.jsdelivr.net/npm/intl-tel-input@18/build/js/intlTelInput.min.js');

    iti = window.intlTelInput(phoneInput, {
      initialCountry: 'auto',
      geoIpLookup: cb => fetch('https://ipapi.co/json/').then(r => r.json()).then(d => cb(d.country_code)).catch(() => cb('US')),
      preferredCountries: [], separateDialCode: true,
      utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@18/build/js/utils.js',
    });

    setTimeout(() => {
      try {
        const names = new Intl.DisplayNames(['es'], { type: 'region' });
        document.querySelectorAll('.iti__country').forEach(el => {
          const code = el.dataset.countryCode?.toUpperCase();
          const nameEl = el.querySelector('.iti__country-name');
          if (code && nameEl) { const es = names.of(code); if (es) nameEl.textContent = es; }
        });
      } catch (_) {}

      const list = document.querySelector('.iti__country-list');
      if (list) {
        const wrap = document.createElement('li'); wrap.className = 'iti-search-wrap';
        const box = document.createElement('input');
        box.type = 'text'; box.placeholder = 'Buscar país...'; box.className = 'iti-custom-search';
        wrap.appendChild(box); list.insertBefore(wrap, list.firstChild);

        box.addEventListener('input', () => {
          const q = box.value.toLowerCase().trim();
          if (q) {
            list.querySelectorAll('.iti__preferred').forEach(el => el.style.display = 'none');
            list.querySelectorAll('.iti__divider').forEach(d => d.style.display = 'none');
            list.querySelectorAll('.iti__country:not(.iti__preferred)').forEach(el => {
              const name = el.querySelector('.iti__country-name')?.textContent.toLowerCase() ?? '';
              const dial = el.querySelector('.iti__dial-code')?.textContent ?? '';
              el.style.display = (name.includes(q) || dial.includes(q)) ? '' : 'none';
            });
          } else {
            list.querySelectorAll('.iti__country').forEach(el => el.style.display = '');
            list.querySelectorAll('.iti__divider').forEach(d => d.style.display = '');
          }
        });
        phoneInput.addEventListener('close:countrydropdown', () => { box.value = ''; list.querySelectorAll('.iti__country').forEach(el => el.style.display = ''); list.querySelectorAll('.iti__divider').forEach(d => d.style.display = ''); });
        phoneInput.addEventListener('open:countrydropdown', () => setTimeout(() => box.focus(), 50));
      }
    }, 0);
  })();

  document.getElementById('checkout-form').addEventListener('submit', async e => {
    e.preventDefault();
    const errBox = document.getElementById('form-error');
    errBox.style.display = 'none';

    const name  = document.getElementById('f-name').value.trim();
    const email = emailInput.value.trim();
    const phone = iti ? iti.getNumber() : phoneInput.value.trim();
    const user  = userInput.value.trim();

    if (!name) { showError('El nombre completo es requerido.'); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) { showError('Ingresa un correo electrónico válido.'); return; }
    if (!iti || !iti.isValidNumber()) { showError('Ingresa un número de teléfono válido con código de país.'); return; }
    if (user && usernameOk === false) { showError('Ese nombre de usuario no está disponible.'); return; }
    if (user && usernameOk === null && user.length >= 3) { showError('Espera a que se verifique el nombre de usuario.'); return; }

    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    document.getElementById('btn-text').textContent = 'Procesando...';

    try {
      const resp = await fetch(`${API_URL}/api/v1/checkout/orders`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ full_name: name, email, whatsapp_number: phone, plan_months: months, country: COUNTRY, brand: BRAND, iptv_username: user || null }),
      });
      const data = await resp.json();
      if (!resp.ok) throw new Error(data.detail ?? 'Error al procesar');
      if (data.payment_link) {
        goPay(data.payment_link);
      } else {
        const fallback = PAYPAL_LINKS[plan.id];
        if (fallback) goPay(fallback);
        else {
          const msg = encodeURIComponent(`Hola, quiero activar el plan ${plan.name} de FlujoTV+ ($${plan.price} USD). Nombre: ${name}`);
          window.location.href = `https://wa.me/${WA_NUMBER}?text=${msg}`;
        }
      }
    } catch (err) {
      showError(err.message || 'Error al procesar tu solicitud. Por favor intenta de nuevo.');
      btn.disabled = false;
      document.getElementById('btn-text').textContent = 'Continuar al pago →';
    }
  });

  function showError(msg) {
    const errBox = document.getElementById('form-error');
    errBox.textContent = msg; errBox.style.display = 'block';
    errBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
