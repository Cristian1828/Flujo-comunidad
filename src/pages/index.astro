---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SearchHero from '../components/SearchHero.astro';
import CommonProblems from '../components/CommonProblems.astro';
import PopularGuides from '../components/PopularGuides.astro';
import DownloadCenter from '../components/DownloadCenter.astro';
import { site } from '../config/site';
---

<Layout>
  <Navbar />
  
  <main>
    <!-- 1. Portal Hero with Search + Quick Access + Live Stats -->
    <SearchHero />

    <!-- 2. Common Problems Grid (replaces Install Guides on home) -->
    <CommonProblems />
    
    <!-- Divider -->
    <div class="section-divider"></div>

    <!-- 3. Magazine-style Popular Guides -->
    <PopularGuides />

    <!-- 4. Download Center (app-store style) -->
    <DownloadCenter />

    <!-- 5. Subtle CTA — Minimal, not aggressive -->
    <section class="py-16 relative overflow-hidden bg-carbon-950">
      <div class="section-container relative z-10">
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-sm text-cream-500 mb-3 uppercase tracking-wider font-semibold">¿Aún no tienes cuenta?</p>
          <h2 class="text-2xl sm:text-3xl font-heading font-bold text-cream-100 mb-4">
            Obtén acceso completo a todo el contenido
          </h2>
          <p class="text-cream-400 mb-8 max-w-xl mx-auto">
            Miles de canales en vivo, películas, series y eventos deportivos. Desde <span class="text-ember-400 font-bold">$9.99/mes</span> con activación inmediata.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
            <a href="/planes" class="btn-ember px-8 py-3.5 text-sm">
              Ver Planes y Precios
            </a>
            <a href={`https://wa.me/${site.whatsappNumber}?text=Hola,%20quiero%20información%20sobre%20planes%20de%20Flujo%20TV`} target="_blank" rel="noopener noreferrer" class="btn-outline px-8 py-3.5 text-sm">
              <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              Consultar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
