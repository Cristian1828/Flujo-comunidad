---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../config/site';

const pageTitle = "Cómo Instalar Flujo TV en Celular y Tablet Android | APK 2026";
const pageDescription = "Descarga gratis el APK oficial de Flujo TV para celulares Android. Instala ahora y mira canales en vivo donde quiera que estés.";

const guide = site.installGuides.find(g => g.id === 'android');
---

<Layout 
  title={pageTitle}
  description={pageDescription}
>
  <Navbar />

  <main class="pt-24 pb-16 min-h-screen">
    <div class="section-container">
      
      <!-- Breadcrumb -->
      <nav class="flex text-cream-500 text-sm mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-ember-400 transition-colors">Inicio</a>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
              </svg>
              <a href="/instalar" class="hover:text-ember-400 transition-colors">Guías de Instalación</a>
            </div>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/>
              </svg>
              <span class="text-cream-300">Celulares Android</span>
            </div>
          </li>
        </ol>
      </nav>

      <!-- Content Grid -->
      <div class="grid lg:grid-cols-3 gap-12">
        
        <!-- Main Content -->
        <article class="lg:col-span-2">
          <header class="mb-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-ember-900/30 text-ember-400 text-sm font-medium border border-ember-500/20 mb-6">
               Versión Móvil Autorizada
            </div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-cream-100 leading-tight mb-6">
              Instalar <span class="text-gradient-ember">Flujo TV</span> en Celular y Tablet Android
            </h1>
            <p class="text-lg text-cream-400 leading-relaxed">
              Lleva todo el entretenimiento en tu bolsillo. Descarga la versión optimizada de Flujo TV para pantallas móviles (Samsung, Motorola, Xiaomi, etc.). 
              Funciona con redes WiFi, 4G y 5G.
            </p>
          </header>

          <!-- Featured Image or Video -->
          <div class="rounded-2xl overflow-hidden border border-cream-500/10 shadow-2xl mb-12 bg-carbon-900 aspect-video">
            <img src={guide?.image} alt="Flujo TV APK Android" class="w-full h-full object-cover opacity-80" />
          </div>

          <!-- Quick Download CTA for Mobile -->
          <div class="mb-12 flex flex-col sm:flex-row items-center justify-between glass-panel p-6 rounded-2xl border border-ember-500/30 bg-gradient-to-r from-ember-900/20 to-carbon-900">
             <div>
               <h3 class="text-lg font-bold text-cream-100 mb-1">Descarga Directa Móvil</h3>
               <p class="text-cream-400 text-sm">Obtén el archivo APK 100% seguro y libre de virus directamente a tu celular.</p>
             </div>
             <div class="mt-4 sm:mt-0">
               <a href={site.download.mobileApkHref} target="_blank" rel="noopener noreferrer" class="btn-ember whitespace-nowrap px-6 py-3 flex items-center gap-2">
                 <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                 Descargar APK Android
               </a>
             </div>
          </div>

          <!-- The Steps -->
          <div class="space-y-8">
            <h2 class="text-2xl font-bold text-cream-100 border-b border-cream-500/10 pb-4">Pasos de Instalación</h2>
            
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-ember-600 flex items-center justify-center text-white font-bold text-lg">1</div>
              <div>
                <h3 class="text-xl font-bold text-cream-200 mb-2">Descargar el archivo APK</h3>
                <p class="text-cream-400 leading-relaxed">
                  Haz clic en el botón de "Descargar APK Android" de arriba desde el navegador (Chrome, Firefox, Samsung Internet) de tu celular. El archivo `.apk` comenzará a bajar inmediatamente.
                </p>
              </div>
            </div>

            <!-- INJECTED CTA FOR SALES -->
            <div class="glass-panel p-6 rounded-xl border border-ember-500/30 bg-gradient-to-r from-ember-900/40 to-carbon-900 my-8">
              <h4 class="text-lg font-bold text-cream-100 mb-2"> Llévalo en todas tus pantallas</h4>
              <p class="text-cream-400 text-sm mb-4">Recuerda que con tu plan oficial de Flujo TV obtienes derecho a **3 pantallas simultáneas**. Puedes ver en la TV de la sala, en la habitación y en tu celular a la vez.</p>
              <a href="/planes" class="text-ember-400 font-bold hover:text-ember-300 text-sm">Contratar Plan Oficial Hoy →</a>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-ember-600 flex items-center justify-center text-white font-bold text-lg">2</div>
              <div>
                <h3 class="text-xl font-bold text-cream-200 mb-2">Permitir Fuentes Desconocidas</h3>
                <p class="text-cream-400 leading-relaxed">
                  Como la app no está en Google Play, tu celular podría mostrarte una alerta de seguridad al intentar abrir el archivo descargado. Haz clic en <strong class="text-cream-200">Configuración</strong> y marca la opción <strong class="text-cream-200">Permitir desde esta fuente</strong> para autorizar a Chrome (o tu navegador) a instalar la app.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-ember-600 flex items-center justify-center text-white font-bold text-lg">3</div>
              <div>
                <h3 class="text-xl font-bold text-cream-200 mb-2">Instalar y Acceder</h3>
                <p class="text-cream-400 leading-relaxed">
                  Presiona "Instalar", espera unos segundos y luego escoge "Abrir". Al entrar a la app, digita tu usuario y contraseña proporcionados por tu distribuidor oficial. Si aún no tienes uno, pide el tuyo desde nuestra sección de planes.
                </p>
              </div>
            </div>
            
            <div class="mt-8 p-4 bg-red-900/20 border border-red-500/20 rounded-xl">
              <p class="text-sm text-red-200 flex items-center gap-2">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                Importante: Flujo TV NO funciona en sistemas iOS (iPhone o iPad). Es una aplicación exclusiva y optimizada para el sistema operativo Android.
              </p>
            </div>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="space-y-8">
          
          <!-- CTA Sidebar -->
          <div class="glass-panel p-6 rounded-2xl border border-ember-500/20 text-center sticky top-28">
            <h3 class="text-xl font-bold text-cream-100 mb-3">Obtén tu Acceso</h3>
            <p class="text-sm text-cream-400 mb-6">Más de 3,000 canales Premium, PPV, Series y Películas. Un solo pago, sin contratos.</p>
            <a href="/planes" class="btn-ember block w-full py-3 mb-4">Ver Planes</a>
            <p class="text-xs text-cream-500">Garantía de servicio e instalación</p>
          </div>

          <!-- Other Guides -->
          <div class="glass-panel p-6 rounded-2xl border border-cream-500/10">
            <h3 class="text-lg font-bold text-cream-100 mb-4">Para Pantallas Grandes</h3>
            <ul class="space-y-3">
              <li>
                <a href="/instalar/fire-stick" class="flex items-center gap-3 text-cream-400 hover:text-ember-400 transition-colors">
                  <span class="text-xl"></span>
                  <span class="text-sm font-medium">Instalar en Fire Stick</span>
                </a>
              </li>
              <li>
                <a href="/instalar/tv-box" class="flex items-center gap-3 text-cream-400 hover:text-ember-400 transition-colors">
                  <span class="text-xl"></span>
                  <span class="text-sm font-medium">Instalar en TV Box</span>
                </a>
              </li>
              <li>
                <a href="/instalar/google-tv" class="flex items-center gap-3 text-cream-400 hover:text-ember-400 transition-colors">
                  <span class="text-xl"></span>
                  <span class="text-sm font-medium">Instalar en Google TV</span>
                </a>
              </li>
            </ul>
          </div>

        </aside>
      </div>

    </div>
  </main>
  
  <Footer />
</Layout>

<!-- HowTo Schema Specific for this page -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo instalar Flujo TV en Celulares Android",
  "description": "Descarga directa e instalación de la APK de Flujo TV en teléfonos y tablets que usen el sistema operativo Android.",
  "image": `${site.canonical}/images/mobile-streaming.webp`,
  "totalTime": "PT2M",
  "step": [
    {
      "@type": "HowToStep",
      "name": "Bajar archivo APK",
      "text": "Haz clic en descargar para guardar el instalador oficial `.apk` en el almacenamiento de tu celular.",
      "url": `${site.canonical}/instalar/android#paso1`
    },
    {
      "@type": "HowToStep",
      "name": "Autorizar Fuentes Desconocidas",
      "text": "Si el navegador te lo pide, ve a ajustes y permite instalar apps desconocidas desde tu navegador (ej. Chrome).",
      "url": `${site.canonical}/instalar/android#paso2`
    },
    {
      "@type": "HowToStep",
      "name": "Instalar la aplicación",
      "text": "Abre el archivo descargado, presiona Instalar, luego ábrelo e introduce tu cuenta.",
      "url": `${site.canonical}/instalar/android#paso3`
    }
  ]
})} />
