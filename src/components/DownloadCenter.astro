            <h3 class="font-heading font-bold text-cream-100 text-base">Fire Stick Â· Google TV</h3>
            <p class="text-xs text-cream-500">Xiaomi Mi Stick incluido</p>
          </div>
        </div>
        <div class="platform-body">
          <p class="text-xs text-cream-500 mb-1">Usa este cÃ³digo en la app Downloader:</p>
          <div class="code-display">
            <span class="text-2xl font-heading font-bold text-gradient-ember tracking-[0.2em]">{site.download.firestickCode}</span>
          </div>
          <a href="/instalar/fire-stick/" class="platform-link">
            Ver guÃ­a paso a paso â†’
          </a>
        </div>
        <div class="platform-badge">CÃ³digo</div>
      </div>

      <!-- Platform 2: Celular / Tablet -->
      <div class="platform-card">
        <div class="platform-header">
          <div class="platform-icon-wrap bg-sky-500/10">
            <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-cream-100 text-base">Android / Tablet</h3>
            <p class="text-xs text-cream-500">Descarga directa del APK</p>
          </div>
        </div>
        <div class="platform-body">
          <a href={site.download.mobileApkHref} target="_blank" rel="noopener" class="download-btn">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
            Descargar APK
          </a>
          <p class="text-[10px] text-cream-600 mt-2 text-center">v4.2.1 Â· 28 MB Â· Android 5.0+</p>
          <a href="/instalar/android/" class="platform-link">
            Ver instrucciones â†’
          </a>
        </div>
        <div class="platform-badge">APK</div>
      </div>

      <!-- Platform 3: TV Box -->
      <div class="platform-card">
        <div class="platform-header">
          <div class="platform-icon-wrap bg-purple-500/10">
            <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.125c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125Z" /></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-cream-100 text-base">TV Box Android</h3>
            <p class="text-xs text-cream-500">Todos los modelos</p>
          </div>
        </div>
        <div class="platform-body">
          <a href={site.download.mobileApkHref} target="_blank" rel="noopener" class="download-btn">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
            Descargar APK
          </a>
          <p class="text-[10px] text-cream-600 mt-2 text-center">Conecta USB o descarga vÃ­a navegador</p>
          <a href="/instalar/tv-box/" class="platform-link">
