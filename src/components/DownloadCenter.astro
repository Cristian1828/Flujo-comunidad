    <!-- Trust bar -->
    <div class="flex flex-wrap justify-center items-center gap-6 sm:gap-10 py-6 px-8 rounded-2xl max-w-3xl mx-auto" style="background: rgba(30, 41, 59, 0.3); border: 1px solid rgba(148, 163, 184, 0.06);">
      <div class="flex items-center gap-2 text-xs text-cream-400">
        <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"></path></svg>
        <span>Verificado libre de virus</span>
      </div>
      <div class="flex items-center gap-2 text-xs text-cream-400">
        <svg class="w-4 h-4 text-ember-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"></path></svg>
        <span>Ãšltima actualizaciÃ³n: Marzo 2026</span>
      </div>
      <div class="flex items-center gap-2 text-xs text-cream-400">
        <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a9 9 0 1 1-18 0V5.25"></path></svg>
        <span>Compatible con +50 dispositivos</span>
      </div>
    </div>
  </div>
</section>

<style>
  .platform-card {
    position: relative;
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: rgba(30, 41, 59, 0.4);
    border: 1px solid rgba(148, 163, 184, 0.08);
    transition: all 0.3s ease;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .platform-card:hover {
    border-color: rgba(6, 182, 212, 0.2);
    box-shadow: 0 8px 40px rgba(6, 182, 212, 0.08);
    transform: translateY(-4px);
  }
  .platform-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .platform-icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .platform-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .code-display {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(6, 182, 212, 0.12);
    border-radius: 0.75rem;
    padding: 1rem;
    text-align: center;
    margin-bottom: 0.75rem;
  }
  .download-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #0284c7, #06b6d4);
    color: #fff;
    font-weight: 700;
    font-size: 0.875rem;
    transition: all 0.3s ease;
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(6, 182, 212, 0.25);
  }
  .download-btn:hover {
    box-shadow: 0 6px 25px rgba(6, 182, 212, 0.4);
    transform: translateY(-2px);
  }
  .platform-link {
    margin-top: auto;
    padding-top: 0.75rem;
    font-size: 0.75rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s ease;
    text-align: center;
  }
  .platform-link:hover {
    color: #22d3ee;
  }
  .platform-badge {
    position: absolute;
    top: 0;
    right: 0;
    background: rgba(6, 182, 212, 0.15);
    color: #22d3ee;
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 0 1.25rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

