---
import { site, getSupportWhatsappLink } from '../config/site';
---

<section class="py-20 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-carbon-900 via-carbon-950 to-carbon-950"></div>
  
  <div class="section-container relative z-10">
    <!-- Section header -->
    <div class="text-center mb-14">
