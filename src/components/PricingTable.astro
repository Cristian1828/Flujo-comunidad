---
import { site, getWhatsappLink } from '../config/site';
---

<section id="planes" class="py-16 sm:py-20 relative overflow-hidden">
  <!-- Background image with gradient -->
  <div class="absolute inset-0">
    <img src="/images/bg-forums-dark.png" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(15,23,42,0.93) 0%, rgba(15,23,42,0.78) 50%, rgba(15,23,42,0.93) 100%);"></div>
  </div>

  <div class="section-container relative z-10">
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="section-heading">Planes</h2>
      <p class="text-cream-400 mt-3 max-w-xl mx-auto">Activación inmediata vía WhatsApp</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto animate-on-scroll">
      {site.pricing.plans.map((plan) => (
        <div class={`glass-card p-5 relative overflow-hidden ${plan.highlight ? 'ring-1 ring-ember-500/50' : ''}`} style="background: rgba(30,41,59,0.55); backdrop-filter: blur(12px);">
          {plan.highlight && (
            <div class="absolute top-0 right-0 text-[10px] font-bold text-white px-3 py-1 rounded-bl-lg" style="background: linear-gradient(135deg, #0284c7, #22d3ee);">
              POPULAR
            </div>
          )}

          <div class="mb-4">
            <h3 class="font-heading font-semibold text-sm text-cream-100">{plan.name}</h3>
            <p class="text-xs text-cream-500 mt-0.5">{plan.duration}</p>
          </div>

          <div class="mb-5">
            <div class="flex items-baseline gap-0.5">
              <span class="text-xs text-cream-500">{site.pricing.currency}</span>
              <span class="text-3xl font-heading font-bold text-gradient-ember">{plan.price}</span>
              <span class="text-xs text-cream-500">.99</span>
            </div>
          </div>

          <div class="space-y-2 mb-6">
            {plan.features.map((feature) => (
              <div class="flex items-start gap-2">
                <svg class="w-3.5 h-3.5 text-ember-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path></svg>
                <span class="text-xs text-cream-400">{feature}</span>
              </div>
            ))}
          </div>

          <a href={plan.paypalUrl} target="_blank" rel="noopener noreferrer nofollow" referrerpolicy="no-referrer" class={`w-full text-center block text-xs py-2.5 rounded-lg font-semibold transition-all ${plan.highlight ? 'btn-ember' : 'btn-outline'}`}>
            Contratar
          </a>
        </div>
      ))}
    </div>

    <!-- WhatsApp Alternative -->
    <div class="mt-8 text-center animate-on-scroll">
      <div class="inline-flex flex-col sm:flex-row items-center gap-3 px-6 py-4 rounded-2xl border border-cream-500/10" style="background: rgba(15,23,42,0.55); backdrop-filter: blur(12px);">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="text-cream-400 text-sm">¿Otros métodos de pago?</span>
        </div>
        <a href={`https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent('Hola, me interesa adquirir un plan de Flujo TV. ¿Qué métodos de pago tienen disponibles?')}`} target="_blank" rel="noreferrer noopener" class="text-green-400 hover:text-green-300 text-sm font-semibold transition-colors underline underline-offset-2">
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
