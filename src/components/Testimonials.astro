---
import { site } from '../config/site';
---

<section id="testimonios" class="py-20 relative">
  <div class="section-container relative z-10">
    <div class="text-center mb-14 animate-on-scroll">
      <span class="badge mb-4"> Experiencias Reales</span>
      <h2 class="section-heading">Lo que Dicen Nuestros Usuarios</h2>
      <p class="section-subheading">Miles de personas en toda Latinoamérica confían en Flujo TV para su entretenimiento diario</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 animate-on-scroll">
      {site.testimonials.map((testimonial, idx) => (
        <div class="glass-card p-6 group" style={`animation-delay: ${idx * 100}ms`}>
          <!-- Stars -->
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="w-4 h-4 text-ember-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            ))}
          </div>

          <!-- Comment -->
          <p class="text-sm text-cream-300 leading-relaxed mb-5 italic">
            "{testimonial.comment}"
          </p>

          <!-- User info -->
          <div class="flex items-center gap-3 pt-4" style="border-top: 1px solid rgba(6,182,212,0.1);">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-heading font-bold text-sm" style="background: linear-gradient(135deg, #0284c7, #06b6d4); color: #ffffff;">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-semibold text-cream-200">{testimonial.name}</p>
              <p class="text-xs text-cream-500">{testimonial.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
