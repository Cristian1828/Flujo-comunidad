---
import { site, getSupportWhatsappLink, getWhatsappLink } from '../config/site';

// Build a simple purchase WhatsApp link
const purchaseWhatsappLink = `https://wa.me/${site.whatsappNumber}?text=${encodeURIComponent('Hola, quiero activar una cuenta de Flujo TV')}`;
---

<!-- SVG icon definitions -->
<svg xmlns="http://www.w3.org/2000/svg" class="hidden">
  <defs>
    <symbol id="icon-firestick" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
      <path d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
    </symbol>
    <symbol id="icon-tvbox" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.125c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125Z" />
    </symbol>
    <symbol id="icon-googletv" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z" />
    </symbol>
    <symbol id="icon-android" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
    </symbol>
    <symbol id="icon-xiaomi" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5.25 7.5A2.25 2.25 0 0 1 7.5 5.25h9a2.25 2.25 0 0 1 2.25 2.25v9a2.25 2.25 0 0 1-2.25 2.25h-9a2.25 2.25 0 0 1-2.25-2.25v-9Z" />
      <path d="M9 9h6v6H9V9Z" />
    </symbol>
  </defs>
</svg>

<section id="guias" class="py-16 sm:py-20 relative overflow-hidden">
  <!-- Background image with gradient -->
  <div class="absolute inset-0">
    <img src="/images/bg-devices.webp" alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(15,23,42,0.94) 0%, rgba(15,23,42,0.82) 50%, rgba(15,23,42,0.94) 100%);"></div>
  </div>
  <div class="section-container relative z-10">
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="section-heading">Selecciona tu Dispositivo</h2>
      <p class="text-cream-400 mt-3 max-w-xl mx-auto">Haz clic en tu dispositivo y sigue la guía</p>
    </div>

    <!-- Device tabs -->
    <div class="flex flex-wrap justify-center gap-3 mb-10 animate-on-scroll">
      {site.installGuides.map((guide) => (
        <button 
          class="device-tab glass-card px-5 py-3 flex items-center gap-3 cursor-pointer transition-all duration-300 hover:border-ember-500" 
          data-device={guide.id}
        >
          <svg class="w-5 h-5 text-cream-400"><use href={`#icon-${guide.id}`}></use></svg>
          <span class="text-sm font-medium text-cream-300">{guide.device}</span>
        </button>
      ))}
    </div>

    <!-- Samsung/LG notice -->
    <div class="text-center mb-10 animate-on-scroll">
      <p class="text-xs text-cream-500 inline-flex items-center gap-2 px-4 py-2 rounded-full" style="background: rgba(234,179,8,0.06); border: 1px solid rgba(234,179,8,0.12);">
        <svg class="w-3.5 h-3.5 text-yellow-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"></path></svg>
        Samsung / LG requieren TV Box o Fire Stick externo
      </p>
    </div>

    <!-- Expandable guide panels -->
    <div class="space-y-4 max-w-3xl mx-auto animate-on-scroll">
      {site.installGuides.map((guide) => (
        <div id={`guide-${guide.id}`} class="guide-panel glass-card overflow-hidden" data-device-panel={guide.id}>
          <!-- Header (clickable) -->
          <button class="guide-panel-trigger w-full text-left p-5 sm:p-6 flex items-center justify-between gap-4 cursor-pointer" aria-expanded="false">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background: linear-gradient(135deg, rgba(6,182,212,0.2), rgba(2,132,199,0.3));">
                <svg class="w-5 h-5 text-ember-300"><use href={`#icon-${guide.id}`}></use></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-cream-100">{guide.device}</h3>
                <p class="text-xs text-cream-500 mt-0.5">{guide.steps.length} pasos · ~5 min</p>
              </div>
            </div>
            <svg class="guide-chevron w-5 h-5 text-cream-500 transition-transform duration-300 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
            </svg>
          </button>

          <!-- Expandable content -->
          <div class="guide-panel-content overflow-hidden transition-all duration-400" style="max-height: 0;">
            <div class="px-5 sm:px-6 pb-6">
              <!-- Steps -->
              <div class="space-y-3 mb-6" style="border-top: 1px solid rgba(6,182,212,0.08); padding-top: 1rem;">
                {guide.steps.map((step, idx) => (
                  <div class="flex gap-3 items-start">
                    <span class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold" style="background: linear-gradient(135deg, #0284c7, #06b6d4); color: #ffffff;">
                      {idx + 1}
                    </span>
                    <p class="text-sm text-cream-300 leading-relaxed pt-1">{step}</p>
                  </div>
                ))}
              </div>

              {/* === FIRE STICK: code + video === */}
              {guide.id === 'firestick' && (
                <div class="space-y-4">
                  <div class="p-4 rounded-xl flex items-center gap-4" style="background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.15);">
                    <svg class="w-5 h-5 text-ember-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z"></path></svg>
                    <div>
                      <p class="text-xs text-cream-500">Código Downloader</p>
                      <p class="text-xl font-heading font-bold text-gradient-ember tracking-widest">{site.download.firestickCode}</p>
                    </div>
                  </div>
                </div>
              )}

              {/* === GOOGLE TV: code + embedded video === */}
              {guide.id === 'googletv' && (
                <div class="space-y-4">
                  <div class="p-4 rounded-xl flex items-center gap-4" style="background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.15);">
                    <svg class="w-5 h-5 text-ember-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z"></path></svg>
                    <div>
                      <p class="text-xs text-cream-500">Código Downloader</p>
                      <p class="text-xl font-heading font-bold text-gradient-ember tracking-widest">{site.download.firestickCode}</p>
                    </div>
                  </div>
                  <!-- Video tutorial inline -->
                  <div>
                    <p class="text-xs text-cream-500 mb-2 font-medium">Video tutorial:</p>
                    <div class="rounded-xl overflow-hidden" style="border: 1px solid rgba(6,182,212,0.1);">
                      <div style="padding-top: 56.25%; position: relative; background: #0f172a;">
                        <iframe 
                          src={`https://fast.wistia.net/embed/iframe/${site.videos.googleTV.hombre}?videoFoam=true`}
                          title="Guía instalación Google TV / Chromecast"
                          allow="autoplay; fullscreen"
                          allowfullscreen
                          style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                          loading="lazy"
                        ></iframe>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* === XIAOMI: code === */}
              {guide.id === 'xiaomi' && (
                <div class="space-y-4">
                  <div class="p-4 rounded-xl flex items-center gap-4" style="background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.15);">
                    <svg class="w-5 h-5 text-ember-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z"></path></svg>
                    <div>
                      <p class="text-xs text-cream-500">Código Downloader</p>
                      <p class="text-xl font-heading font-bold text-gradient-ember tracking-widest">{site.download.firestickCode}</p>
                    </div>
                  </div>
                </div>
              )}

              {/* === ANDROID (Celular/Tablet): solo APK directo === */}
              {guide.id === 'android' && (
                <div class="space-y-4">
                  <a href={site.download.mobileApkHref} target="_blank" rel="noopener" class="btn-ember text-sm py-3 inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"></path></svg>
                    Descargar APK Actualizado
                  </a>
                </div>
              )}

              {/* === TV BOX: APK download + video tutorial === */}
              {guide.id === 'tvbox' && (
                <div class="space-y-4">
                  <a href={site.download.mobileApkHref} target="_blank" rel="noopener" class="btn-ember text-sm py-3 inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"></path></svg>
                    Descargar APK Actualizado
                  </a>
                  <!-- Video tutorial inline -->
                  <div>
                    <p class="text-xs text-cream-500 mb-2 font-medium">Video tutorial:</p>
                    <div class="rounded-xl overflow-hidden" style="border: 1px solid rgba(6,182,212,0.1);">
                      <div style="padding-top: 56.25%; position: relative; background: #0f172a;">
                        <iframe 
                          src={`https://fast.wistia.net/embed/iframe/${site.videos.androidTV.hombre}?videoFoam=true`}
                          title="Guía instalación TV Box Android"
                          allow="autoplay; fullscreen"
                          allowfullscreen
                          style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                          loading="lazy"
                        ></iframe>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* === UNIVERSAL: Help + Account CTAs === */}
              <div class="mt-5 pt-4 flex flex-col sm:flex-row gap-3" style="border-top: 1px solid rgba(6,182,212,0.06);">
                <a href={getSupportWhatsappLink()} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-xs text-cream-400 hover:text-green-400 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
                  ¿Necesitas ayuda? →
                </a>
                <a href={purchaseWhatsappLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-xs text-cream-500 hover:text-ember-300 transition-colors">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"></path></svg>
                  ¿Quieres una cuenta? →
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.device-tab');
  const panels = document.querySelectorAll('.guide-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const deviceId = tab.getAttribute('data-device');
      const panel = document.querySelector(`[data-device-panel="${deviceId}"]`);
      if (panel) {
        panels.forEach(p => {
          if (p !== panel) {
            const content = p.querySelector('.guide-panel-content') as HTMLElement;
            const chevron = p.querySelector('.guide-chevron') as HTMLElement;
            const trigger = p.querySelector('.guide-panel-trigger');
            if (content) content.style.maxHeight = '0';
            if (chevron) chevron.style.transform = 'rotate(0deg)';
            trigger?.setAttribute('aria-expanded', 'false');
            p.classList.remove('ring-1', 'ring-ember-500/30');
          }
        });

        const content = panel.querySelector('.guide-panel-content') as HTMLElement;
        const chevron = panel.querySelector('.guide-chevron') as HTMLElement;
        const trigger = panel.querySelector('.guide-panel-trigger');
        const isOpen = trigger?.getAttribute('aria-expanded') === 'true';

        if (!isOpen) {
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
          trigger?.setAttribute('aria-expanded', 'true');
          panel.classList.add('ring-1', 'ring-ember-500/30');
          panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        tabs.forEach(t => t.classList.remove('!border-ember-500', '!bg-ember-500/10'));
        tab.classList.add('!border-ember-500', '!bg-ember-500/10');
      }
    });
  });

  document.querySelectorAll('.guide-panel-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const panel = trigger.closest('.guide-panel');
      const content = panel?.querySelector('.guide-panel-content') as HTMLElement;
      const chevron = panel?.querySelector('.guide-chevron') as HTMLElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      panels.forEach(p => {
        if (p !== panel) {
          const c = p.querySelector('.guide-panel-content') as HTMLElement;
          const ch = p.querySelector('.guide-chevron') as HTMLElement;
          const t = p.querySelector('.guide-panel-trigger');
          if (c) c.style.maxHeight = '0';
          if (ch) ch.style.transform = 'rotate(0deg)';
          t?.setAttribute('aria-expanded', 'false');
          p.classList.remove('ring-1', 'ring-ember-500/30');
        }
      });

      if (!isOpen) {
        content.style.maxHeight = content.scrollHeight + 'px';
        chevron.style.transform = 'rotate(180deg)';
        trigger.setAttribute('aria-expanded', 'true');
        panel?.classList.add('ring-1', 'ring-ember-500/30');
      } else {
        content.style.maxHeight = '0';
        chevron.style.transform = 'rotate(0deg)';
        trigger.setAttribute('aria-expanded', 'false');
        panel?.classList.remove('ring-1', 'ring-ember-500/30');
      }
    });
  });

  const hash = window.location.hash;
  if (hash && hash.startsWith('#guide-')) {
    const deviceId = hash.replace('#guide-', '');
    const tab = document.querySelector(`.device-tab[data-device="${deviceId}"]`) as HTMLElement;
    if (tab) setTimeout(() => tab.click(), 500);
  }
</script>
