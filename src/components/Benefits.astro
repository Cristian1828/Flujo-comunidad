---
const benefits = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"></path></svg>`,
    title: 'Tecnología Anti-Freeze',
    description: 'Señal estable sin cortes ni interrupciones.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.125c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125Z"></path></svg>`,
    title: '+3,000 Canales en Vivo',
    description: 'Deportes, noticias, cine y más.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"></path></svg>`,
    title: 'Calidad 4K Real',
    description: 'Servidores privados de alta velocidad.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"></path></svg>`,
    title: '3 Pantallas Simultáneas',
    description: 'Comparte con toda tu familia.',
  },
];
---

<section id="beneficios" class="py-16 sm:py-20 relative">
  <div class="section-container relative z-10">
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="section-heading">¿Por qué Flujo TV?</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 max-w-4xl mx-auto animate-on-scroll">
      {benefits.map((benefit) => (
        <div class="glass-card p-5 text-center group">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4 text-ember-300" style="background: linear-gradient(135deg, rgba(6,182,212,0.12), rgba(2,132,199,0.18));">
            <Fragment set:html={benefit.icon} />
          </div>
          <h3 class="font-heading font-semibold text-sm text-cream-100 mb-1.5">{benefit.title}</h3>
          <p class="text-xs text-cream-500 leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
