---
import { site, getSupportWhatsappLink } from '../config/site';
const currentYear = new Date().getFullYear();
---

<footer class="pt-12 pb-6 relative bg-carbon-950" style="border-top: 1px solid rgba(6,182,212,0.1);">
  <div class="section-container">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/images/logo_flujo.webp" alt="Flujo TV" class="w-8 h-8 rounded-lg object-contain" />
          <span class="font-heading text-lg font-bold text-cream-100">
            Flujo<span class="text-gradient-ember">TV+</span>
          </span>
        </div>
        <p class="text-xs text-cream-500 leading-relaxed">Centro oficial de guías y soporte.</p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-xs font-semibold text-cream-300 uppercase tracking-wider mb-3">Navegación</h4>
        <ul class="space-y-2">
          <li><a href="/instalar/" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">Guías</a></li>
          <li><a href="/descargar-apk/" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">Descarga</a></li>
          <li><a href="/faq/" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">FAQ</a></li>
          <li><a href="/planes/" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">Planes</a></li>
        </ul>
      </div>

      <!-- Devices -->
      <div>
        <h4 class="text-xs font-semibold text-cream-300 uppercase tracking-wider mb-3">Dispositivos</h4>
        <ul class="space-y-2">
          <li><a href="/instalar/fire-stick" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">Fire Stick</a></li>
          <li><a href="/instalar/tv-box" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">TV Box</a></li>
          <li><a href="/instalar/google-tv" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">Google TV</a></li>
          <li><a href="/instalar/android" class="text-xs text-cream-500 hover:text-ember-300 transition-colors">Android</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-semibold text-cream-300 uppercase tracking-wider mb-3">Contacto</h4>
        <div class="space-y-2">
          <a href={getSupportWhatsappLink()} target="_blank" rel="noopener" class="flex items-center gap-2 text-xs text-cream-500 hover:text-green-400 transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            +51 914 326 729
          </a>
          <a href={`mailto:${site.email}`} class="flex items-center gap-2 text-xs text-cream-500 hover:text-ember-300 transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"></path></svg>
            {site.email}
          </a>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="text-[10px] text-cream-600 text-center leading-relaxed mb-6 max-w-2xl mx-auto">
      Equipo independiente de ventas y soporte. No alojamos contenido con derechos de autor. Todas las marcas pertenecen a sus respectivos dueños. Compatible solo con Android.
    </p>

    <!-- Bottom -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-4" style="border-top: 1px solid rgba(6,182,212,0.06);">
      <p class="text-[10px] text-cream-600">© {currentYear} {site.brand.name}</p>
      <div class="flex items-center gap-4">
        <a href="/privacidad/" class="text-[10px] text-cream-600 hover:text-ember-300 transition-colors">Privacidad</a>
        <a href="/terminos/" class="text-[10px] text-cream-600 hover:text-ember-300 transition-colors">Términos</a>
      </div>
    </div>
  </div>
</footer>
