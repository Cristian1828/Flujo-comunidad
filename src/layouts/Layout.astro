---
import { site, canonicalUrl } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  ogImage?: string;
  noIndex?: boolean;
}

const { 
  title = site.seo.title,
  description = site.seo.description,
  keywords = site.seo.keywords,
  ogImage = site.seo.ogImage,
  noIndex = false
} = Astro.props;

const canonical = canonicalUrl(Astro.url.pathname);
const keywordsString = keywords.join(', ');
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

// Schema.org Organization
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.brand.name,
  url: site.canonical,
  logo: `${site.canonical}/images/logo_flujo.webp`,
  description: site.brand.description,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: `+${site.whatsappNumber}`,
    contactType: 'customer service',
    availableLanguage: ['Spanish', 'es'],
    areaServed: site.targetCountries.map(c => c.code),
  },
  sameAs: [
    'https://www.facebook.com/flujooficial',
    'https://www.instagram.com/flujooficial',
    'https://x.com/flujooficial'
  ]
};

// Schema.org WebSite with SearchAction
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.brand.name,
  alternateName: ['Flujo TV', 'FlujoTV', 'Flujo TV Pro', 'Flujo TV Premium', 'Flujo TV Oficial'],
  url: site.canonical,
  description: site.seo.description,
  inLanguage: 'es',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${site.canonical}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string'
  }
};

// Schema.org Product with offers
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Flujo TV Premium — Streaming +3000 Canales en Vivo, Películas 4K',
  description: 'Servicio de streaming premium con más de 3,000 canales en vivo, películas, series y deportes en calidad 4K. Compatible con Fire Stick, TV Box, Google TV, Chromecast y Android. Tecnología Anti-Freeze.',
  image: `${site.canonical}/images/hero-streaming.webp`,
  url: site.canonical,
  brand: { '@type': 'Brand', name: site.brand.name },
  category: 'Streaming & Entertainment',
  offers: site.pricing.plans.map(plan => ({
    '@type': 'Offer',
    name: `${plan.name} — ${plan.duration}`,
    price: plan.price,
    priceCurrency: site.pricing.currencyCode,
    availability: 'https://schema.org/InStock',
    url: `${site.canonical}/#planes`,
    priceValidUntil: '2027-12-31',
    itemCondition: 'https://schema.org/NewCondition',
    seller: { '@type': 'Organization', name: site.brand.name },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: { '@type': 'MonetaryAmount', value: 0, currency: 'USD' },
      shippingDestination: { '@type': 'DefinedRegion', addressCountry: site.targetCountries.map(c => c.code) },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 0, unitCode: 'DAY' },
        transitTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 0, unitCode: 'DAY' }
      }
    },
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: site.targetCountries.map(c => c.code),
      returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
      merchantReturnDays: 0,
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/FreeReturn'
    }
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '3850',
    bestRating: '5',
    worstRating: '1'
  },
  review: site.testimonials.slice(0, 3).map(t => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: t.name },
    datePublished: '2026-01-15',
    reviewBody: t.comment,
    reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5 }
  }))
};

// Schema.org SoftwareApplication
const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Flujo TV',
  operatingSystem: 'Android',
  applicationCategory: 'MultimediaApplication',
  applicationSubCategory: 'Streaming',
  offers: {
    '@type': 'Offer',
    price: '9',
    priceCurrency: 'USD'
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    ratingCount: '3850'
  },
  downloadUrl: site.download.mobileApkHref,
  featureList: '3000+ canales en vivo, Películas 4K, Series, Deportes en vivo, 3 pantallas simultáneas, Anti-Freeze',
  screenshot: `${site.canonical}/images/hero-streaming.webp`,
};

// Schema.org FAQPage
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: site.faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};

// Schema.org HowTo (install guide)
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Cómo instalar Flujo TV en Fire Stick, TV Box, Google TV y Android',
  description: 'Guía paso a paso para instalar la aplicación Flujo TV en todos los dispositivos compatibles: Amazon Fire Stick, TV Box Android, Google TV, Chromecast, Xiaomi Mi Stick, celulares y tablets Android.',
  totalTime: 'PT5M',
  supply: [{ '@type': 'HowToSupply', name: 'Dispositivo Android (Fire Stick, TV Box, Google TV, celular o tablet)' }],
  tool: [{ '@type': 'HowToTool', name: 'App Downloader (código 9249124)' }],
  step: site.installGuides[0].steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: `Paso ${i + 1}`,
    text: step,
    url: `${site.canonical}/#guide-firestick`
  }))
};

// Schema.org BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.canonical },
    ...(Astro.url.pathname !== '/' ? [{
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: canonical
    }] : [])
  ]
};

import '../styles/global.css';
---

<!doctype html>
<html lang="es-419" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="referrer" content="no-referrer" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Preload LCP -->
    <link rel="preload" as="image" href="/images/hero-tech-streaming.png" fetchpriority="high" />

    <link rel="icon" type="image/webp" href="/images/logo_flujo.webp" />
    <link rel="apple-touch-icon" href="/images/logo_flujo.webp" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://wa.me" />
    <link rel="dns-prefetch" href="https://fast.wistia.net" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordsString} />
    <meta name="author" content={site.brand.name} />
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content="Flujo TV" />
    <meta name="subject" content="Streaming de TV en vivo, películas y series" />
    <meta name="copyright" content={`${site.brand.name} ${new Date().getFullYear()}`} />
    <meta name="reply-to" content={site.email} />
    <meta name="rating" content="general" />
    <meta name="distribution" content="global" />
    <meta name="coverage" content="Worldwide" />
    <meta name="target" content="all" />
    <meta name="HandheldFriendly" content="True" />
    
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/manifest.json" />
    
    {noIndex ? (
      <>
        <meta name="robots" content="noindex, nofollow" />
        <meta name="googlebot" content="noindex, nofollow" />
        <meta name="bingbot" content="noindex, nofollow" />
      </>
    ) : (
      <>
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
        <meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
        <meta name="bingbot" content="index, follow" />
      </>
    )}
    
    <!-- Language & Geo Targeting -->
    <meta name="language" content="Spanish" />
    <meta http-equiv="content-language" content="es" />
    <meta name="geo.region" content="419" />
    <meta name="geo.placename" content="Latinoamérica" />
    
    <!-- hreflang: generic + each target country + default -->
    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="es-419" href={canonical} />
    {site.targetCountries.map(country => (
      <link rel="alternate" hreflang={country.lang} href={canonical} />
    ))}
    <link rel="alternate" hreflang="x-default" href={canonical} />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${site.canonical}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Flujo TV — Streaming premium con +3,000 canales en vivo" />
    <meta property="og:locale" content="es_LA" />
    <meta property="og:locale:alternate" content="es_PE" />
    <meta property="og:locale:alternate" content="es_CO" />
    <meta property="og:locale:alternate" content="es_MX" />
    <meta property="og:locale:alternate" content="es_CL" />
    <meta property="og:locale:alternate" content="es_AR" />
    <meta property="og:locale:alternate" content="es_EC" />
    <meta property="og:locale:alternate" content="es_BO" />
    <meta property="og:locale:alternate" content="es_VE" />
    <meta property="og:locale:alternate" content="es_US" />
    <meta property="og:site_name" content={site.brand.name} />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.canonical}${ogImage}`} />
    <meta name="twitter:image:alt" content="Flujo TV — Streaming premium con +3,000 canales en vivo" />
    {site.seo.twitterHandle && <meta name="twitter:site" content={site.seo.twitterHandle} />}
    {site.seo.twitterHandle && <meta name="twitter:creator" content={site.seo.twitterHandle} />}
    
    <!-- PWA / Mobile -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Flujo TV" />
    <meta name="theme-color" content="#0D0D0D" />
    <meta name="msapplication-TileColor" content="#06b6d4" />
    
    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..800;1,9..40,300..800&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-carbon-900 text-cream-100 font-body">
    <slot />

    <!-- Scroll Animation Observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
